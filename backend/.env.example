# --- Admin login (used by the admin UI) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
JWT_SECRET=please-change-this-to-a-long-random-string

# --- Chain access (read-only queries + optional relayer) ---
# A Sepolia JSON-RPC endpoint (Infura/Alchemy/public).
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
CHAIN_ID=11155111

# Optional: private key the backend uses to register voters on-chain
# (the "backend sends transactions" role). Must be the Registration owner.
# Leave blank to disable the relayer endpoint.
REGISTRAR_PRIVATE_KEY=

# Server
PORT=4000
